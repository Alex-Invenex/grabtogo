{
  "name": "@grabtogo/api-client",
  "version": "0.1.0",
  "description": "API client for GrabtoGo services",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9",
    "tsup": "^8.0.0",
    "typescript": "^5"
  },
  "keywords": [
    "api",
    "client",
    "http",
    "grabtogo"
  ],
  "author": "GrabtoGo Team",
  "license": "MIT"
}