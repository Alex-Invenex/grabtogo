# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/grabtogo_db?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/grabtogo_db?schema=public"

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_REFRESH_SECRET=your_super_secure_jwt_refresh_secret_key_here
JWT_EXPIRY=1d
JWT_REFRESH_EXPIRY=7d

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=grabtogo-uploads

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_firebase_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_CLIENT_ID=your_firebase_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_CLIENT_CERT_URL=your_firebase_client_cert_url

# SMTP Configuration for Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM_NAME=GrabtoGo
SMTP_FROM_EMAIL=noreply@grabtogo.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Frontend URLs
WEB_APP_URL=http://localhost:3000
MOBILE_APP_DEEP_LINK=grabtogo://

# API Configuration
API_BASE_URL=http://localhost:3001
API_VERSION=v1

# Socket.IO Configuration
SOCKET_IO_ORIGINS=http://localhost:3000,http://localhost:3001

# Notification Configuration
FCM_SERVER_KEY=your_fcm_server_key_here
PUSH_NOTIFICATION_VAPID_PUBLIC_KEY=your_vapid_public_key_here
PUSH_NOTIFICATION_VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Analytics Configuration
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX-X

# Security Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Subscription Configuration
TRIAL_PERIOD_DAYS=14
BASIC_PLAN_PRICE=999
STANDARD_PLAN_PRICE=1999
PREMIUM_PLAN_PRICE=2999

# Geolocation Configuration
DEFAULT_SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=50

# Cache Configuration
CACHE_TTL_SECONDS=3600
REDIS_CACHE_PREFIX=grabtogo:

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log